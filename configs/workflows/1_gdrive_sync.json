{
  "name": "Sync SatStream Images",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 1
            }
          ]
        }
      },
      "name": "Schedule",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$env.RCLONE_SYNC_ENABLED}}",
              "value2": "true"
            }
          ]
        }
      },
      "name": "Check Sync Enabled",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "command": "rclone copy drivename:/satstream_images /output --config=$RCLONE_CONFIG --ignore-existing"
      },
      "name": "Execute Rclone",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        700,
        280
      ]
    }
  ],
  "connections": {
    "Schedule": {
      "main": [
        [
          {
            "node": "Check Sync Enabled",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check Sync Enabled": {
      "main": [
        [
          {
            "node": "Execute Rclone",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true
}
