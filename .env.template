# ==============================================================================
# Configuración del entorno NOAA Climate Information System - Server
# ==============================================================================

# ------------------------------------------------------------------------------
# Rutas del Host (Sistema anfitrión)
# ------------------------------------------------------------------------------
# Directorio donde se guardan las imágenes PNG procesadas a servir
HOST_PNG_OUTPUT_DIR=./png-images
# Directorio donde descargar las imágenes originales (ej via rclone/n8n)
HOST_RAW_IMAGES_DIR=./raw_images
# Directorio base para las configuraciones del proyecto (n8n, grafana, telegraf, etc.)
HOST_CONFIG_DIR=./configs

# ------------------------------------------------------------------------------
# Configuración de InfluxDB
# ------------------------------------------------------------------------------
INFLUXDB_INIT_MODE=setup
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=adminpassword
INFLUXDB_INIT_ORG=noaa_org
INFLUXDB_INIT_BUCKET=telemetry
INFLUXDB_INIT_ADMIN_TOKEN=my-super-secret-auth-token

# ------------------------------------------------------------------------------
# Configuración de Nginx Gallery
# ------------------------------------------------------------------------------
GALLERY_PORT=8080

# ------------------------------------------------------------------------------
# Configuración de Grafana
# ------------------------------------------------------------------------------
GRAFANA_PORT=3000

# ------------------------------------------------------------------------------
# Configuración de n8n (Automatización)
# ------------------------------------------------------------------------------
# Puerto externo donde se expone la interfaz de n8n
N8N_PORT=5678
# Habilitar sincronización con rclone dentro de los flujos de n8n
RCLONE_SYNC_ENABLED=true
