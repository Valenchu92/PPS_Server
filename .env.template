# ==============================================================================
# Configuración del entorno NOAA Climate Information System
# ==============================================================================

# ------------------------------------------------------------------------------
# Rutas del Host (Sistema anfitrión)
# ------------------------------------------------------------------------------
# Directorio donde se depositan los archivos de audio WAV originales
HOST_WAV_INPUT_DIR=./input-wav
# Directorio donde se guardan las imágenes PNG procesadas
HOST_PNG_OUTPUT_DIR=./png-images
# Directorio donde se guardan las imágenes crudas (RAW) descargadas
HOST_RAW_IMAGES_DIR=./raw_images
# Directorio base para las configuraciones del proyecto
HOST_CONFIG_DIR=./configs

# ------------------------------------------------------------------------------
# Configuración del Procesador NOAA
# ------------------------------------------------------------------------------
# Edad máxima en días de los archivos WAV a conservar antes de ser eliminados
PROCESSOR_MAX_AGE_DAYS=7
# Intervalo de tiempo en minutos en el que se ejecuta la limpieza de archivos
PROCESSOR_CLEANUP_INTERVAL_MIN=60

# ------------------------------------------------------------------------------
# Configuración de Immich (Galería de imágenes)
# ------------------------------------------------------------------------------
# Versión de la imagen Docker de Immich Server
IMMICH_VERSION=release
# Puerto externo donde se expone Immich
IMMICH_PORT=2283

# Credenciales de la Base de Datos PostgreSQL de Immich
DB_USERNAME=postgres
DB_PASSWORD=immich_password
DB_DATABASE_NAME=immich

# ------------------------------------------------------------------------------
# Configuración de n8n (Automatización)
# ------------------------------------------------------------------------------
# Puerto externo donde se expone la interfaz de n8n
N8N_PORT=5678
